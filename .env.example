# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (SQLite in development)
DATABASE_URL=sqlite:///db.sqlite3

# Frontend
FRONTEND_BASE_URL=http://localhost:5173

# Email Configuration (REQUIRED for password reset emails to work)
# Option 1: Gmail SMTP (requires app password, not regular password)
# 1. Enable 2FA on your Google account
# 2. Create app password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@nobonir.com

# Option 2: Mailtrap (Free tier available)
# 1. Sign up at https://mailtrap.io
# 2. Copy SMTP credentials from your inbox
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_HOST_USER=your-mailtrap-username
# EMAIL_HOST_PASSWORD=your-mailtrap-password
# EMAIL_PORT=2525
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=noreply@nobonir.com

# Option 3: SendGrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=noreply@nobonir.com

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=24

# Stripe (if using payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI/Ollama Settings
AI_OLLAMA_API_URL=http://127.0.0.1:11434
AI_OLLAMA_MODEL=phi
AI_FREE_LLM_ENABLED=true
AI_FREE_LLM_TIMEOUT_SECONDS=12

# Cache
REDIS_URL=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Logging
LOG_LEVEL=INFO
